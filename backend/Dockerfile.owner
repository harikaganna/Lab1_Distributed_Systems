FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY shared/ shared/
COPY services/owner_service/ services/owner_service/
RUN mkdir -p uploads
EXPOSE 8006
CMD ["uvicorn", "services.owner_service.main:app", "--host", "0.0.0.0", "--port", "8006"]
